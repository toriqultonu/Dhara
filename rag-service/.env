# ── Database ──
DATABASE_URL=postgresql+asyncpg://dhara:dhara_secret@localhost:5432/dhara

# ── Embedding Provider: bgem3 | ollama | openai ──
EMBEDDING_PROVIDER=bgem3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ── LLM Provider: ollama | deepseek | gemini | claude | openai ──
LLM_PROVIDER=ollama
LLM_MODEL=deepseek-r1:8b

# ── LLM Routing Mode: local | smart ──
LLM_ROUTING_MODE=local

# ── Reranker Provider: bge | cohere | noop ──
RERANKER_PROVIDER=bge
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Ollama (local models) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── DeepSeek API ──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Google Gemini API ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic Claude API ──
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── OpenAI API ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Cohere API ──
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# ── Search Config ──
SEARCH_VECTOR_WEIGHT=0.7
SEARCH_BM25_WEIGHT=0.3
SEARCH_DEFAULT_LIMIT=20

# ── gRPC ──
GRPC_PORT=50051

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
